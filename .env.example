# Supabase — copy to .env.local and fill from Settings → API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated Supabase auth user UUIDs granted the /admin console.
# Must also be set in Vercel → Settings → Environment Variables (Production).
ADMIN_USER_IDS=
