---
import { measurables, honors } from '../data/site';
---

<section class="section section--alt" id="athletics">
  <div class="wrap">
    <p class="eyebrow reveal">The Profile</p>
    <h2 class="section-title reveal">Measurables</h2>

    {honors.length > 0 && (
      <div class="honors reveal">
        {honors.map((h) => (
          <span class="badge">★ {h}</span>
        ))}
      </div>
    )}

    <h3 class="group-label reveal">Athletic Testing</h3>
    <div class="grid">
      {measurables.map((s) => (
        <div class={`tile reveal ${s.placeholder ? 'is-placeholder' : ''}`}>
          <div class="tile__value">{s.value}</div>
          <div class="tile__label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .honors { margin-top: 1.8rem; display: flex; flex-wrap: wrap; gap: 0.8rem; }

  .group-label {
    font-family: var(--display); font-weight: 700;
    font-size: 0.95rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted); margin-top: 3rem; margin-bottom: 1.1rem;
    display: flex; align-items: center; gap: 0.9rem;
  }
  .group-label::after { content: ''; flex: 1; height: 1px; background: var(--line); }

  .grid {
    display: grid; gap: 0.9rem;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }

  .note { margin-top: 1.2rem; color: var(--faint); font-size: 0.88rem; }
</style>
