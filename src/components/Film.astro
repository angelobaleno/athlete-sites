---
import { film } from '../data/site';
---

<section class="section" id="film">
  <div class="wrap">
    <p class="eyebrow reveal">The Tape</p>
    <h2 class="section-title reveal">Watch the Film</h2>

    <div class="film reveal">
      <iframe
        src={film.hudlEmbed}
        title={`${film.title} — Hudl`}
        allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <p class="film__links reveal">
      <a href={film.hudlWatch} target="_blank" rel="noopener">hudl.com/v/2T3jkn</a>
      <span aria-hidden="true">·</span>
      <a href={film.hudlProfile} target="_blank" rel="noopener">Full Hudl profile</a>
    </p>
  </div>
</section>

<style>
  .film {
    position: relative;
    margin-top: 2.5rem; aspect-ratio: 16 / 9; max-height: 620px;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--ink-3);
    overflow: hidden;
  }
  .film iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%; border: 0;
  }

  .film__links {
    margin-top: 1.4rem; color: var(--muted);
    font-size: 0.92rem; display: flex; gap: 0.7rem; flex-wrap: wrap;
  }
  .film__links a { color: var(--purple-hi); }
  .film__links a:hover { color: var(--bone); }
</style>
