---
import { player } from '../data/site';
---

<header class="nav">
  <div class="wrap nav__inner">
    <a href="#top" class="brand" aria-label={`${player.first} ${player.last} home`}>
      <span class="brand__mark">TB</span>
      <span class="brand__name">{player.last}<span class="brand__dot">.</span></span>
    </a>

    <nav class="nav__links" aria-label="Section navigation">
      <a href="#film">Film</a>
      <a href="#offers">Offers</a>
      <a href="#athletics">Athletics</a>
      <a href="#schedule">Schedule</a>
    </nav>

    <a href="#contact" class="btn btn--gold nav__cta">
      Contact
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(14, 14, 16, 0.82);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 66px; gap: 1.5rem;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.65rem; }
  .brand__mark {
    font-family: var(--display); font-weight: 900; font-size: 0.95rem;
    letter-spacing: 0.04em; color: var(--gold);
    background: var(--purple);
    width: 34px; height: 34px; border-radius: 4px;
    display: grid; place-content: center;
  }
  .brand__name {
    font-family: var(--display); font-weight: 800;
    font-size: 1.15rem; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--bone);
  }
  .brand__dot { color: var(--gold); }

  .nav__links { display: flex; gap: 1.75rem; }
  .nav__links a {
    font-family: var(--display); font-weight: 600;
    font-size: 0.9rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); transition: color 0.15s ease;
  }
  .nav__links a:hover { color: var(--bone); }

  .nav__cta { padding: 0.6rem 1.1rem; font-size: 0.85rem; }

  @media (max-width: 720px) {
    .nav__links { display: none; }
  }
</style>
