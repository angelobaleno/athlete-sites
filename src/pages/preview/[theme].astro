---
// Dev-only theme workbench: render any registered theme over Tyler's data.
import { loadAthleteSite } from '../../lib/athlete-site';
import { getTheme } from '../../themes/registry';
import ThemeRender from '../../components/ThemeRender.astro';

export const prerender = false;

// Dev-only: hide in production builds.
if (!import.meta.env.DEV) return new Response('Not found', { status: 404 });

const themeName = Astro.params.theme!;
const t = await getTheme(themeName);     // fail-loud on unknown theme

const site = await loadAthleteSite('tyler-baleno');
if (!site) return new Response('Athlete not found', { status: 404 });
---

<ThemeRender theme={t} panels={site.panels} player={site.player} />
