---
import Admin from '../layouts/Admin.astro';
import LoginForm from '../components/admin/LoginForm.tsx';
export const prerender = false;
---
<Admin title="Sign in">
  <h1>Athlete Login</h1>
  <p>Sign in to manage your recruiting page.</p>
  <LoginForm client:load />
  <p><a href="/forgot" class="forgot">Forgot password?</a></p>
  <style>
    h1 { font-family: var(--a-display); }
    .forgot { color: var(--a-accent); font-size: 0.9rem; }
  </style>
</Admin>
