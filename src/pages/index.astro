---
// Default tenant: the deployment's bare domain serves Tyler (athlete #1).
// Each athlete also has a per-slug route under /s/ that statically imports
// their own theme; custom domains rewrite there (see docs/NEW-ATHLETE.md).
// When the platform gets its own marketing page, it replaces this file.
import { tylerTheme } from '../themes/tyler';
import { loadAthleteSite } from '../lib/athlete-site';
import ThemeRender from '../components/ThemeRender.astro';

export const prerender = false;

const site = await loadAthleteSite('tyler-baleno');
if (!site) return new Response('Athlete not found', { status: 404 });

// Public page: let Vercel's CDN serve it. Athlete edits show within a minute;
// most recruiter views never touch Supabase.
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
---

<ThemeRender theme={tylerTheme} panels={site.panels} player={site.player} />
