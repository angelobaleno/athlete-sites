---
import Admin from '../../layouts/Admin.astro';
import LogoutButton from '../../components/admin/LogoutButton.tsx';
import SectionEditor from '../../components/admin/SectionEditor.tsx';
import OffersEditor from '../../components/admin/OffersEditor.tsx';
import { getOwnedAthlete } from '../../lib/athlete-admin';
import { offerRows } from '../../lib/offers-admin';
import { SECTIONS, sectionFieldViews } from '../../lib/profile-sections';
import { resolveOffers } from '../../lib/athlete';
export const prerender = false;

// Middleware guarantees a user here, but guard defensively.
const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const record = await getOwnedAthlete(Astro.locals.supabase, user.id);

const editors = record
  ? SECTIONS.map((def) => ({
      section: def.key,
      title: def.title,
      fields: sectionFieldViews(def, record.profile[def.key]),
    }))
  : [];

// Raw offers are what the editor saves back; the resolved twins only feed labels —
// so a save can't freeze school-table data or wipe hand-set overrides.
const rows = record
  ? offerRows(record.profile.offers, await resolveOffers(record.profile.offers))
  : [];
---
<Admin title="Dashboard">
  <header class="admin-header">
    <div>
      <h1>Your Dashboard</h1>
      <p class="signed-in">Signed in as {user.email}</p>
    </div>
    <LogoutButton client:load />
  </header>

  <p><a href="/" class="view-site">View my public site →</a></p>

  {record ? (
    <>
      {editors.map((e) => (
        <SectionEditor client:load section={e.section} title={e.title} fields={e.fields} />
      ))}
      <OffersEditor client:load rows={rows} />
    </>
  ) : (
    <p class="no-record">No editable record is linked to this account yet.</p>
  )}

  <style>
    .admin-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; }
    h1 { font-family: var(--a-display); }
    .signed-in { color: var(--a-muted); font-size: 0.85rem; margin: 0.25rem 0 0; }
    .view-site { color: var(--a-accent); }
    .no-record { color: var(--a-muted); margin-top: 2rem; }
  </style>
</Admin>
