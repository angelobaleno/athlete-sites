---
import type { Game, AthleteProfile } from '../../lib/types';
interface Props { schedule: Game[]; scheduleMeta: AthleteProfile['scheduleMeta']; }
const { schedule, scheduleMeta } = Astro.props;
---
{schedule.length > 0 && (
  <section>
    <h2>Schedule — {scheduleMeta.season}</h2>
    <ul>{schedule.map((g) => (<li>{g.date} — {g.home ? 'vs' : '@'} {g.opp}</li>))}</ul>
  </section>
)}
