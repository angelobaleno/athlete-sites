---
import type { Offer } from '../../lib/types';
import { assetUrl } from '../../lib/display';
interface Props { offers: Offer[]; }
const { offers } = Astro.props as Props;
const asset = (p: string) => assetUrl(p, import.meta.env.BASE_URL);
---

<section class="section" id="offers">
  <div class="wrap">
    <p class="eyebrow reveal">Recruitment</p>
    <h2 class="section-title reveal">College Offers</h2>

    <div class="offers">
      {offers.map((o) => (
        <div class="offer reveal">
          {o.logoUrl ? (
            <div class="offer__logo"><img src={asset(o.logoUrl)} alt={`${o.school} logo`} loading="lazy" /></div>
          ) : (
            <div class="offer__mark" aria-hidden="true">{o.short}</div>
          )}
          <div class="offer__body">
            <span class="offer__tag">Offer</span>
            <p class="offer__school">{o.school}</p>
            <p class="offer__level">{o.level}</p>
            <p class="offer__loc">{o.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .offers {
    margin-top: 2.5rem; display: grid; gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
  }
  .offer {
    display: flex; align-items: center; gap: 1.6rem;
    background: var(--ink-3); border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1.8rem; position: relative; overflow: hidden;
  }
  .offer::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 3px; background: linear-gradient(90deg, var(--gold), var(--purple)); }

  .offer__mark {
    flex: none; width: 92px; height: 92px; border-radius: 6px;
    display: grid; place-content: center;
    font-family: var(--display); font-weight: 900; font-size: 2rem; letter-spacing: 0.02em;
    color: var(--gold); background: var(--purple);
    border: 2px solid var(--gold);
  }
  .offer__logo {
    flex: none; width: 92px; height: 92px; border-radius: 6px;
    background: #fff; display: grid; place-content: center; padding: 12px;
  }
  .offer__logo img { width: 100%; height: 100%; object-fit: contain; }
  .offer__tag {
    font-family: var(--display); font-weight: 700; font-size: 0.72rem;
    letter-spacing: 0.24em; text-transform: uppercase; color: var(--gold);
  }
  .offer__school {
    font-family: var(--display); font-weight: 800; font-size: clamp(1.4rem, 3vw, 1.9rem);
    text-transform: uppercase; letter-spacing: 0.01em; line-height: 1; margin-top: 0.5rem;
  }
  .offer__level { color: var(--bone); font-weight: 500; margin-top: 0.6rem; }
  .offer__loc { color: var(--muted); font-size: 0.9rem; margin-top: 0.15rem; }

  /* Narrow phones: give the school name room next to the logo. */
  @media (max-width: 480px) {
    .offer { gap: 1.1rem; padding: 1.4rem; }
    .offer__logo, .offer__mark { width: 72px; height: 72px; }
    .offer__mark { font-size: 1.6rem; }
  }
</style>
